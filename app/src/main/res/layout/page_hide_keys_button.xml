<?xml version="1.0" encoding="utf-8"?>
<com.limelight.binding.input.advance_setting.superpage.SuperPageLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:tag="280">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:paddingVertical="12dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/crown_config_panel_bg"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp">

            <!-- 页面标题 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_button_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 隐藏按键设置卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_section_settings"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>

                <!-- 子按键可见性 -->
                <CheckBox
                    android:id="@+id/page_hide_keys_child_visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_child_visible"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginBottom="8dp"
                    android:paddingVertical="4dp"/>

                <!-- 按键文本 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/layout_page_digital_combine_button_text_bab9f"
                        android:textSize="12sp"
                        android:textColor="#B3FFFFFF"
                        android:layout_marginBottom="6dp"/>
                    <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                        android:id="@+id/page_hide_keys_text"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:background="@drawable/crown_config_input_bg"
                        android:textSize="15sp"
                        android:paddingHorizontal="12dp"/>
                </LinearLayout>

                <!-- 选择被隐藏按键 -->
                <LinearLayout
                    android:id="@+id/page_hide_keys_select_child_button"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/crown_config_input_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hide_keys_select_buttons"
                        android:textSize="14sp"/>
                    <View
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/crown_right_arrow"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 触控模式选择卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_section_touch_mode"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_touch_mode_description"
                    android:textSize="12sp"
                    android:textColor="#99FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/page_hide_keys_touch_mode_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/page_hide_keys_mode_mouse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_mouse"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>

                    <RadioButton
                        android:id="@+id/page_hide_keys_mode_trackpad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_trackpad"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>

                    <RadioButton
                        android:id="@+id/page_hide_keys_mode_multi_touch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_multi_touch"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>
                </RadioGroup>
            </LinearLayout>

            <!-- 按键显示时触控模式卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_section_default_touch_mode"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hide_keys_default_touch_mode_description"
                    android:textSize="12sp"
                    android:textColor="#99FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/page_hide_keys_default_touch_mode_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/page_hide_keys_default_mode_mouse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_mouse"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>

                    <RadioButton
                        android:id="@+id/page_hide_keys_default_mode_trackpad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_trackpad"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>

                    <RadioButton
                        android:id="@+id/page_hide_keys_default_mode_multi_touch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/hide_keys_mode_multi_touch"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:paddingVertical="4dp"/>
                </RadioGroup>
            </LinearLayout>

            <!-- 位置和尺寸卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_position_size"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="8dp"/>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_central_x"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/page_label_coord_x"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_central_y"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/page_label_coord_y"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_width"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_digital_combine_button_ea5a1"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_height"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    app:text="@string/apptext_pg_digital_combine_button_4296d"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />
            </LinearLayout>

            <!-- 外观样式卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_appearance"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="8dp"/>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_radius"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_digital_combine_button_3ebb3"
                    app:max="100"
                    app:min="0"
                    app:progress="0"/>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_thick"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_analog_stick_ae177"
                    app:max="10"
                    app:min="0"
                    app:progress="3"/>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_layer"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    app:text="@string/apptext_pg_analog_stick_6896d"
                    app:max="140"
                    app:min="40" />
            </LinearLayout>

            <!-- 颜色配置卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_color_config"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>

                <!-- 边框颜色行 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_9b4ba"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_hide_keys_normal_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#FFFFFF"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_3142e"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_hide_keys_pressed_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#00FF00"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- 背景颜色 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/layout_page_analog_stick_text_4573a"
                        android:textSize="11sp"
                        android:textColor="#B3FFFFFF"
                        android:layout_marginBottom="4dp"/>
                    <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                        android:id="@+id/page_hide_keys_background_color"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="#80000000"
                        android:textSize="11sp"
                        android:background="@drawable/crown_color_input_bg"
                        android:paddingHorizontal="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 文字设置卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_text_settings"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="8dp"/>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_hide_keys_text_size"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="8dp"
                    app:text="@string/apptext_pg_analog_stick_5f15e"
                    app:max="150"
                    app:min="10"
                    app:progress="63"/>

                <!-- 文字颜色行 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_69066"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_hide_keys_normal_text_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#FFFFFF"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_4b292"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_hide_keys_pressed_text_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#000000"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/page_hide_keys_delete"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="10dp"
                android:text="@string/layout_config_item_text_2f4aa"
                android:textSize="13sp"/>
        </LinearLayout>
    </ScrollView>
</com.limelight.binding.input.advance_setting.superpage.SuperPageLayout>
