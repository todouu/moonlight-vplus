<?xml version="1.0" encoding="utf-8"?>
<com.limelight.binding.input.advance_setting.superpage.SuperPageLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:tag="280">
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:paddingVertical="12dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/crown_config_panel_bg"
        android:scrollbars="none"
        android:fillViewport="true">
        
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp">
            
            <!-- 页面标题 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/layout_page_digital_stick_text_23611"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
            
            <!-- 摇杆配置卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_stick_config"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/layout_page_digital_stick_text_6c35d"
                    android:textSize="12sp"
                    android:textColor="#B3FFFFFF"
                    android:layout_marginBottom="8dp"/>
                
                <!-- 十字形按键布局 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">
                    
                    <!-- 上键 -->
                    <TextView
                        android:id="@+id/page_digital_stick_up_value"
                        android:layout_width="70dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="↑ UP"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/crown_config_input_bg"/>
                    
                    <!-- 左右键 -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="6dp">
                        <TextView
                            android:id="@+id/page_digital_stick_left_value"
                            android:layout_width="70dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:text="← LEFT"
                            android:textSize="12sp"
                            android:background="@drawable/crown_config_input_bg"/>
                        <View
                            android:layout_width="70dp"
                            android:layout_height="44dp"
                            android:layout_marginHorizontal="6dp"/>
                        <TextView
                            android:id="@+id/page_digital_stick_right_value"
                            android:layout_width="70dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:text="RIGHT →"
                            android:textSize="12sp"
                            android:background="@drawable/crown_config_input_bg"/>
                    </LinearLayout>
                    
                    <!-- 下键 -->
                    <TextView
                        android:id="@+id/page_digital_stick_down_value"
                        android:layout_width="70dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="↓ DOWN"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/crown_config_input_bg"/>
                </LinearLayout>
                
                <!-- 中间按键 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/layout_page_analog_stick_text_fb050"
                        android:textSize="12sp"
                        android:textColor="#B3FFFFFF"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/page_digital_stick_middle_value"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="LSB"
                        android:background="@drawable/crown_config_input_bg"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/crown_stick_special_value"
                        android:textSize="12sp"
                        android:textColor="#B3FFFFFF"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/page_digital_stick_special_value"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="@string/crown_stick_special_default"
                        android:background="@drawable/crown_config_input_bg"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_special_hit_radius"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    app:text="@string/crown_stick_special_hit_radius"
                    app:max="300"
                    app:min="100"
                    app:progress="130" />

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_special_trigger_radius"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="6dp"
                    app:text="@string/crown_stick_special_trigger_radius"
                    app:max="300"
                    app:min="100"
                    app:progress="120" />
            </LinearLayout>
            
            <!-- 位置和尺寸卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_position_size"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="8dp"/>
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_central_x"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/page_label_coord_x"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_central_y"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    app:text="@string/page_label_coord_y"
                    app:max="100"
                    app:min="0"
                    app:progress="100" />
            </LinearLayout>
            
            <!-- 外观样式卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_appearance"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="8dp"/>
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_sense"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_analog_stick_4b26d"
                    app:max="100"
                    app:min="0"
                    app:progress="30" />
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_radius"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_analog_stick_b7e19"
                    app:max="100"
                    app:min="0"
                    app:progress="0"/>
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_thick"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="6dp"
                    app:text="@string/apptext_pg_analog_stick_ae177"
                    app:max="10"
                    app:min="0"
                    app:progress="3"/>
                
                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_digital_stick_layer"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    app:text="@string/apptext_pg_analog_stick_6896d"
                    app:max="140"
                    app:min="40" />
            </LinearLayout>
            
            <!-- 颜色配置卡片 -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/crown_config_section_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_section_color_config"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0"
                    android:layout_marginBottom="10dp"/>
                
                <!-- 边框颜色行 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_9b4ba"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_digital_stick_normal_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#FFFFFF"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>
                    
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_page_analog_stick_text_3142e"
                            android:textSize="11sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginBottom="4dp"/>
                        <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                            android:id="@+id/page_digital_stick_pressed_color"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="#00FF00"
                            android:textSize="11sp"
                            android:background="@drawable/crown_color_input_bg"
                            android:paddingHorizontal="6dp"/>
                    </LinearLayout>
                </LinearLayout>
                
                <!-- 背景颜色 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/layout_page_analog_stick_text_4573a"
                        android:textSize="11sp"
                        android:textColor="#B3FFFFFF"
                        android:layout_marginBottom="4dp"/>
                    <com.limelight.binding.input.advance_setting.superpage.ElementEditText
                        android:id="@+id/page_digital_stick_background_color"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="#80000000"
                        android:textSize="11sp"
                        android:background="@drawable/crown_color_input_bg"
                        android:paddingHorizontal="6dp"/>
                </LinearLayout>
            </LinearLayout>
            
            <!-- 操作按钮 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/page_digital_stick_copy"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/layout_capability_diagnostic_text_79d3a"
                    android:textSize="13sp"/>
                <Button
                    android:id="@+id/page_digital_stick_delete"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="@string/layout_config_item_text_2f4aa"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</com.limelight.binding.input.advance_setting.superpage.SuperPageLayout>
