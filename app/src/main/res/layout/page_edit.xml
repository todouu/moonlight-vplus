<?xml version="1.0" encoding="utf-8"?>
<com.limelight.binding.input.advance_setting.superpage.SuperPageLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="match_parent"
    android:tag="320">

    <ScrollView
        android:id="@+id/page_edit_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginEnd="5dp"
        android:background="@drawable/crown_config_panel_bg"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/crown_page_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/crown_config_section_bg"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_edit_text_e8341"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/page_edit_drag_edit_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:textOff=""
                        android:textOn=""
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/crown_alignment_snap_switch"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/page_edit_alignment_snap_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:textOff=""
                        android:textOn=""
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/page_edit_edit_grid_width"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="4dp"
                    app:max="100"
                    app:min="1"
                    app:progress="1"
                    app:text="@string/apptext_pg_edit_458a8" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_digital_common_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_2c372"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_digital_switch_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_c0c18"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_digital_movable_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_5817f"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_pad"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_061fc"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_analog_stick"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_e0cc1"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_digital_stick"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_6d757"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_invisible_analog_stick"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_9851e"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_invisible_digital_stick"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_b4881"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_simplify_performance"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_e19e5"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_digital_combine_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_ed364"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_wheel_pad"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_1483c"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_group_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_edit_text_bd823"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_edit_add_hide_keys_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/hide_keys_button_add"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/crown_text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="15dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/page_edit_auto_color_all"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/crown_auto_color_all_action"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_auto_color"
            android:tint="@color/crown_text_primary" />

        <ImageButton
            android:id="@+id/page_edit_exit_edit_mode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/layout_page_edit_text_b8a5e"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_exit"
            android:tint="@color/crown_text_primary" />
    </LinearLayout>
</com.limelight.binding.input.advance_setting.superpage.SuperPageLayout>
